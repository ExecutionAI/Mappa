# Supabase (https://supabase.com → Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your-publishable-key
SUPABASE_SERVICE_KEY=your-secret-key

# OpenAI
OPENAI_API_KEY=sk-...

# Resend (https://resend.com)
RESEND_API_KEY=re_ejw
FROM_EMAIL=MAPPA Travels <contacto@mappatravels.com
PAOLA_EMAIL=contacto@mappatravels.com 

# Admin dashboard (set a strong random string)
ADMIN_TOKEN=change-me-to-a-strong-secret

# Google Sheets
# 1. Create a Google Cloud project
# 2. Enable the Google Sheets API
# 3. Create a Service Account and download the JSON key
# 4. Share your Google Sheet with the service account email (Editor)
# 5. Copy the sheet ID from the URL: https://docs.google.com/spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEET_ID=1ABC...xyz
GOOGLE_CLIENT_EMAIL=service-account-name@your-project.iam.gserviceaccount.com
# Paste the private_key value from the service account JSON (keep the \n line breaks)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvAIBADA...\n-----END PRIVATE KEY-----\n"
